# Port the HTTP + Socket.IO server listens on
PORT=3001

# How long (ms) a player has to act before the server auto-resolves their turn
# (auto-draw when playing, auto-pick color on a pending Wild). Default 45000.
TURN_TIMEOUT_MS=45000

# Log verbosity: debug | info | warn | error | silent.
# Defaults to "debug" in development and "info" in production.
LOG_LEVEL=

# Comma-separated list of allowed browser origins for CORS.
# Use "*" only for local development. In production set your real frontend URL(s),
# e.g. CORS_ORIGIN=https://unoverse.example.com,https://www.unoverse.example.com
CORS_ORIGIN=*

# Room persistence backend so in-progress games survive a server restart:
#   file   (default) - one JSON snapshot per room on local disk. Zero infra.
#   redis            - shared store; required for running multiple instances.
#   memory           - no persistence (original behaviour).
STORE=file

# Directory for the file store (only used when STORE=file). Defaults to ./.data/rooms
# DATA_DIR=./.data/rooms

# Redis connection string (required when STORE=redis).
# e.g. redis://localhost:6379 or rediss://user:pass@host:6380
# REDIS_URL=redis://localhost:6379
